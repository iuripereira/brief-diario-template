# .env.example — copie para .env (chmod 600, gitignored). Em produção use GitHub Secrets.

# Claude headless
CLAUDE_CODE_OAUTH_TOKEN=

# E-mail (entrega) — SMTP autenticado
MAIL_METHOD=smtp
SMTP_URL=smtps://smtp.gmail.com:465      # ajuste ao seu provedor (ver CONNECTORS.md)
SMTP_USER=voce@exemplo.com
SMTP_PASS=                                # App Password (Gmail exige 2FA)
EMAIL_FROM=Brief Diário <voce@exemplo.com>
EMAIL_TO=voce@exemplo.com

# Tarefas (MCP) — se usar Todoist
TODOIST_API_TOKEN=

# Entrega em chat — preencha conforme entrega.chat.tipo
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Agendador (Cloudflare Worker) — só no scheduler/.dev.vars, não aqui
# GH_DISPATCH_TOKEN=
